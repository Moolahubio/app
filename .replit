modules = ["nodejs-24", "postgresql-16", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "circles"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow]]
name = "circles"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run test:circles"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 23183
externalPort = 3000

[userenv]

[userenv.shared]
BASE_NETWORK = "base-sepolia"
BASE_RPC_URL = "https://sepolia.base.org"
USDC_CONTRACT_ADDRESS = "0x036CbD53842c5426634e7929541eC2318f3dCF7e"
BASE_EXPLORER_URL = "https://sepolia.basescan.org"
NEXT_PUBLIC_BASE_CHAIN = "baseSepolia"
NEXT_PUBLIC_BASE_RPC_URL = "https://sepolia.base.org"
NEXT_PUBLIC_USDC_ADDRESS = "0x036CbD53842c5426634e7929541eC2318f3dCF7e"
NEXT_PUBLIC_ONRAMP = "false"
NEXT_PUBLIC_BASE_ACCOUNT = "false"
EMAIL_FROM = "MoolaHub <noreply@moolahub.io>"
APP_URL = "https://moolahub.io"
CIRCLE_FACTORY_ADDRESS = "0x013e2f7d212Dd06302998a53D4775Fdda126ca4C"
GOAL_VAULT_ADDRESS = "0xba9D507B7E7f9d3A8B8b28946A4C2F0d4E9781b1"
TREASURY_ADDRESS = "0x2C25dE21170668BFA0DDC1967F746d1D4f5FE8c2"
REPUTATION_ADDRESS = "0x7F78497494AB186d62200b279bb63aB8d5281b2D"
ESCROW_IMPL_ADDRESS = "0xfd6EeE6a3D4208b877a95C19f348F1e7661Dc49A"

[userenv.development]

[nix]
channel = "stable-25_05"
