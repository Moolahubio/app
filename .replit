modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "circles"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow]]
name = "circles"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run test:circles"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 23183
externalPort = 3000

[userenv]

[userenv.shared]
BASE_NETWORK = "base-sepolia"
BASE_RPC_URL = "https://sepolia.base.org"
USDC_CONTRACT_ADDRESS = "0xf03C3dA6fb2a59775043CAC8ABfb75c4627728bB"
BASE_EXPLORER_URL = "https://sepolia.basescan.org"
NEXT_PUBLIC_BASE_CHAIN = "baseSepolia"
NEXT_PUBLIC_BASE_RPC_URL = "https://sepolia.base.org"
NEXT_PUBLIC_USDC_ADDRESS = "0xf03C3dA6fb2a59775043CAC8ABfb75c4627728bB"
NEXT_PUBLIC_ONRAMP = "false"
NEXT_PUBLIC_BASE_ACCOUNT = "false"
EMAIL_FROM = "MoolaHub <noreply@moolahub.io>"
APP_URL = "https://moolahub.io"
CIRCLE_FACTORY_ADDRESS = "0xFc71AFbfff5d9D864ba05200Ea2749b5e8472D65"
GOAL_VAULT_ADDRESS = "0xE5aE97765c3e72a181fbB09cABEdAD5d26d09874"
TREASURY_ADDRESS = "0x4989d711869a6d3C26Eb138598B9319d406B2987"
REPUTATION_ADDRESS = "0x69e71ccFCc7624A2f85de7145144f2721eF71fF9"
ESCROW_IMPL_ADDRESS = "0x00b3654521158f1aC4D9a10FA5CD6ad9F00E30Bc"
ACCUMULATION_FACTORY_ADDRESS = "0x4c14Ab5392EE986996235D9570539E672B880b5f"
