# Moolahub — environment reference (Monad Testnet migration)
#
# Placeholders only — NEVER commit real secrets. Copy to `.env` (gitignored) and
# fill in. Variable names track docs/monad-migration-plan.md §7 (env matrix).
#
# Network target: Monad Testnet — chainId 10143, native gas token MON (18 dp).
# USDC is Circle native testnet USDC (6 dp). See docs/monad-migration-plan.md.

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://user:password@host:5432/moolahub

# ---------------------------------------------------------------------------
# Contracts — Foundry deploy (contracts/, run on the deploy host)
#   foundry.toml exposes the `monad_testnet` rpc + etherscan profiles.
# ---------------------------------------------------------------------------
# RPC + verifier the foundry.toml profiles interpolate:
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz
MONADSCAN_API_KEY=your-etherscan-v2-multichain-api-key   # Etherscan v2, chain 10143

# Deploy inputs. USDC_ADDRESS / OWNER_ADDRESS / GUARDIAN_ADDRESS are REQUIRED by
# the deploy scripts (fail-closed) — they are NEVER defaulted to the deployer.
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_TESTNET_KEY
USDC_ADDRESS=0xCIRCLE_NATIVE_MONAD_TESTNET_USDC          # [VERIFY] Circle native, 6 dp
OWNER_ADDRESS=0xYOUR_OWNER_MULTISIG
GUARDIAN_ADDRESS=0xYOUR_GUARDIAN
FEE_RECIPIENT_ADDRESS=0xYOUR_FEE_RECIPIENT               # optional; defaults to deployed Treasury
FEE_BPS=200                                              # 2% (cap 5%)
# Set after the core stack deploys (read by DeployAccumulation):
TREASURY_ADDRESS=0xDEPLOYED_TREASURY
REPUTATION_ADDRESS=0xDEPLOYED_REPUTATION

# ---------------------------------------------------------------------------
# Backend chain config (artifacts/api-server)
#   M2 renames BASE_* -> CHAIN_*/MONAD_* with back-compat reads
#   (e.g. CHAIN_RPC_URL ?? BASE_RPC_URL). Until M2 lands, the BASE_* names are
#   what the code reads — both are listed so the file is correct pre/post M2.
# ---------------------------------------------------------------------------
CHAIN_RPC_URL=https://testnet-rpc.monad.xyz             # M2 name
CHAIN_EXPLORER_URL=https://testnet.monadvision.com      # M2 name (Monad Testnet explorer)
CHAIN_ID=10143                                           # optional explicit chain id
# Legacy aliases still read by current code (retired in M2):
BASE_RPC_URL=https://testnet-rpc.monad.xyz
BASE_EXPLORER_URL=https://testnet.monadvision.com
# BASE_NETWORK no longer gates base vs baseSepolia after M2; leave unset.

# Deployed Monad contract addresses (outputs of the deploy):
USDC_CONTRACT_ADDRESS=0xCIRCLE_NATIVE_MONAD_TESTNET_USDC
CIRCLE_FACTORY_ADDRESS=0xDEPLOYED_CIRCLE_FACTORY
ACCUMULATION_FACTORY_ADDRESS=0xDEPLOYED_ACCUMULATION_FACTORY
GOAL_VAULT_ADDRESS=0xDEPLOYED_GOAL_VAULT

# Platform signer (pays gas / settles). SAME key works on Monad — fund it with
# MON from https://faucet.monad.xyz. Type-2 txs only (Monad has no blob txs).
PLATFORM_PRIVATE_KEY=0xYOUR_PLATFORM_KEY

# Testnet-only toggles (must stay off on a real-money network):
ENABLE_TEST_FAUCET=false        # only relevant if a MockUSDC faucet is deployed
ENABLE_DEPOSIT_SYNC=false

# Indexer (re-tune against Monad ~400ms blocks + public RPC limits 50/25 rps):
INDEXER_INTERVAL_MS=20000

# ---------------------------------------------------------------------------
# Privy (auth/identity on the backend; embedded/smart wallets on the frontend)
#   Enable Monad Testnet (10143) + register the ERC-4337 paymaster in the Privy
#   dashboard, else the gasless flow breaks. Server code is chain-agnostic.
# ---------------------------------------------------------------------------
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# ---------------------------------------------------------------------------
# Frontend (artifacts/moolahub-app, VITE_* baked at build time)
# ---------------------------------------------------------------------------
VITE_PRIVY_APP_ID=your-privy-app-id
VITE_CHAIN_NAME=Monad Testnet   # replaces VITE_BASE_NETWORK (retired in M3)
