# ---- Local dev environment (gitignored) ----
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/moolahub?schema=public"

# 32-byte hex keys for app-level encryption + session signing
APP_ENCRYPTION_KEY="<openssl rand -hex 32>"
SESSION_SECRET="<openssl rand -hex 32>"

# Stellar
STELLAR_NETWORK="testnet"
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"
# Platform issuer/distributor for the testnet USDC stand-in (populated by: npm run stellar:init)
STELLAR_USDC_ISSUER_PUBLIC=""
STELLAR_USDC_ISSUER_SECRET=""
STELLAR_DISTRIBUTOR_PUBLIC=""
STELLAR_DISTRIBUTOR_SECRET=""

# Email (Resend) — production secret; dev logs to console when unset
RESEND_API_KEY=""
EMAIL_FROM="MoolaHub <noreply@moolahub.io>"
APP_URL="http://localhost:3000"

# Privy auth — production secrets; falls back to email/password when unset
PRIVY_APP_ID=""
PRIVY_APP_SECRET=""
NEXT_PUBLIC_PRIVY_APP_ID=""
